# ============================================================
# Instagram DM Platform — environment variables
# Nusxa oling: cp .env.example .env
# .env faylini HECH QACHON gitga qoshmang!
# ============================================================

# ==== PostgreSQL (docker-compose) ====
POSTGRES_USER=instagram_dm
POSTGRES_PASSWORD=
POSTGRES_DB=instagram_dm

# Local (Dockersiz) ishga tushirishda backend uchun:
DATABASE_URL=postgresql://instagram_dm:parol@localhost:5432/instagram_dm

# ==== Auth ====
# Yaratish: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ==== Access token shifrlash (AES-256-GCM) ====
# Aynan 64 ta hex belgi (32 bayt). Yaratish: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ==== Instagram / Meta ====
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
# Meta Dashboarddagi webhook verify token (admin paneldagi bilan bir xil bolishi mumkin)
INSTAGRAM_VERIFY_TOKEN=

# ==== URLlar ====
# Local: http://localhost:3000 / http://localhost:4000
# Production: https://dm.example.com / https://api-dm.example.com
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ==== Admin (deploy.sh avtomatik yaratadi) ====
ADMIN_EMAIL=
ADMIN_PASSWORD=
