# ==== Server ====
NODE_ENV=development
PORT=4000

# ==== Database ====
DATABASE_URL=postgresql://instagram_dm:change-me@localhost:5432/instagram_dm

# ==== Auth ====
# Yaratish: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ==== Access token shifrlash (AES-256) ====
# Aynan 64 ta hex belgi (32 bayt). Yaratish: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ==== Instagram / Meta ====
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_VERIFY_TOKEN=

# ==== URLlar ====
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
